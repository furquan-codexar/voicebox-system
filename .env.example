# Voicebox environment (copy to .env and edit as needed)
# start.sh sources .env from the repo root when present.

# TTS workers for bulk voice clone. Default in code: 4. Max. workers limit: 12.
# Use 1-4 for 8-16GB VRAM; 8-12 for 40GB+ VRAM.
VOICEBOX_TTS_WORKERS=4

# Optional: override backend and web ports (start.sh)
# VOICEBOX_BACKEND_PORT=17493
# VOICEBOX_WEB_PORT=5173
